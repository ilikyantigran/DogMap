          "type": "string"
        },
        "userId": {
          "type": "string",
          "title": "string UUID"
        }
      }
    },
    "v1ResendVerificationRequest": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        }
      }
    },
    "v1ResendVerificationResponse": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "v1VerifyEmailRequest": {
      "type": "object",
      "properties": {
        "token": {
          "type": "string",
          "description": "Opaque single-use verification token from the emailed link."
        }
      }
    },
    "v1VerifyEmailResponse": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
