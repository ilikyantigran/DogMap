          "type": "string"
        },
        "token": {
          "type": "string",
          "title": "opaque session token"
        },
        "userId": {
          "type": "string",
          "title": "string UUID"
        }
      }
    },
    "v1LogoutRequest": {
      "type": "object",
      "description": "Logout takes no body ids; the acting user is derived from the auth_token\nheader. Body kept empty on purpose."
    },
    "v1LogoutResponse": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "v1RegisterRequest": {
      "type": "object",
