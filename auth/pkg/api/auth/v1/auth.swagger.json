        "login": {
          "type": "string",
          "description": "Need (login OR email) AND password. Both id fields are optional; at least\none must be present. Enforced in the handler, not by validate rules."
        },
        "email": {
          "type": "string"
        },
        "password": {
          "type": "string"
        }
