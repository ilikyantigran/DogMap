{
  "name": "dogmap-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DogMap web app — Vue 3 + TypeScript + Vite + Pinia + Vue Router",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.14",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^15.11.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.1.10"
  }
}
