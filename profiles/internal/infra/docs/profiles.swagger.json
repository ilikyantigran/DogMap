          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "friends": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Friend"
          }
        },
        "incomingRequests": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1IncomingRequest"
          }
        },
        "outgoingRequests": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1OutgoingRequest"
          }
        }
      }
    },
    "v1OutgoingRequest": {
      "type": "object",
      "properties": {
        "toUserId": {
          "type": "string"
        },
        "friendRequestId": {
          "type": "string"
        }
      }
    },
    "v1Pet": {
      "type": "object",
      "properties": {
        "breed": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "sex": {
          "type": "string",
          "title": "\"M\" | \"F\""
        },
        "isCastrated": {
          "type": "boolean"
        },
        "age": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "v1SendFriendRequestRequest": {
      "type": "object",
      "properties": {
        "userIdTarget": {
          "type": "string"
        }
      }
    },
    "v1SendFriendRequestResponse": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "friendRequestId": {
          "type": "string"
        }
      }
    },
    "v1SendFriendResponseRequest": {
      "type": "object",
      "properties": {
        "friendRequestId": {
          "type": "string"
        },
        "resolution": {
          "type": "boolean",
          "title": "true = accept, false = decline"
        }
      }
    },
    "v1StatusResponse": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "v1TargetRequest": {
      "type": "object",
      "properties": {
        "userIdTarget": {
          "type": "string"
        }
      },
      "description": "TargetRequest is the shared shape for RemoveFriend/BlockUser/UnblockUser."
    }
  }
}
