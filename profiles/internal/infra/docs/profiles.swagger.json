    "/v1/profiles/edit": {
      "post": {
        "summary": "EditUser updates the *acting user's own* profile (name/surname/phone/pets).\nNo user_id in the body; login/email are not editable here.",
        "operationId": "ProfilesService_EditUser",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetUserInfoResponse"
