        ]
      }
    },
    "/v1/profiles/get": {
      "post": {
        "summary": "GetUserInfo returns the target's profile. Full shape (incl. email/phone) to\nself or friends; reduced shape (no PII) to non-friends.",
        "operationId": "ProfilesService_GetUserInfo",
        "responses": {
          "200": {
            "description": "A successful response.",
