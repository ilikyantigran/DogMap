  "definitions": {
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1EditUserRequest": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "No user_id: acting user comes from the token."
        },
        "surname": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "pets": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Pet"
          }
        }
      }
    },
    "v1Friend": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "login": {
          "type": "string"
        },
        "onWalk": {
          "type": "boolean",
          "title": "derived by Map; false for MVP in Profiles"
        },
        "currentObjectId": {
          "type": "string"
        }
      }
    },
    "v1FriendStatus": {
      "type": "string",
      "enum": [
        "FRIEND_STATUS_NONE",
        "FRIEND_STATUS_PENDING_OUT",
        "FRIEND_STATUS_PENDING_IN",
        "FRIEND_STATUS_FRIENDS",
        "FRIEND_STATUS_BLOCKED"
      ],
      "default": "FRIEND_STATUS_NONE",
      "description": "FriendStatus is computed for the calling user relative to a target.\n\n - FRIEND_STATUS_PENDING_OUT: caller sent a request that is still pending\n - FRIEND_STATUS_PENDING_IN: target sent the caller a pending request\n - FRIEND_STATUS_BLOCKED: caller blocked target, or target blocked caller"
    },
    "v1GetUserInfoRequest": {
      "type": "object",
      "properties": {
        "userIdTarget": {
          "type": "string"
        }
      }
    },
    "v1GetUserInfoResponse": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "login": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "surname": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "title": "full shape only"
        },
        "phone": {
          "type": "string",
          "title": "full shape only"
        },
        "pets": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Pet"
          }
        },
        "onWalk": {
          "type": "boolean",
          "title": "derived by Map; Profiles reports false for MVP"
        },
        "currentObjectId": {
          "type": "string",
          "title": "full shape only; empty when not on a walk"
        },
        "friendStatus": {
          "$ref": "#/definitions/v1FriendStatus"
        },
        "hasPii": {
          "type": "boolean",
          "title": "true = full shape returned, false = reduced"
        }
      },
      "description": "GetUserInfoResponse carries the full shape for self/friends and the reduced\nshape for non-friends. In the reduced shape `email` and `phone` are empty and\n`current_object_id` is omitted; `has_pii` marks which shape this is."
    },
    "v1IncomingRequest": {
      "type": "object",
      "properties": {
        "fromUserId": {
          "type": "string"
        },
        "fromLogin": {
          "type": "string"
        },
        "friendRequestId": {
          "type": "string"
        }
      }
    },
    "v1ListFriendsRequest": {
      "type": "object"
    },
    "v1ListFriendsResponse": {
      "type": "object",
      "properties": {
